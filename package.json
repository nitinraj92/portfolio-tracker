{
  "name": "portfolio-tracker",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "deploy": "echo 'Push: git push origin main | On VM: git pull && pm2 restart portfolio'"
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "xirr": "^1.0.9",
    "xlsx": "^0.18.5",
    "yahoo-finance2": "^2.11.3"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
